@model List<AsFi.Models.StudentResultDto>
@{
    ViewData["Title"] = "Мои оценки";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lecture-view.css" asp-append-version="true" />
</head>
<body>
    <div class="decoration decoration-1"></div>
    <div class="decoration decoration-2"></div>

    <header class="main-header">
        <div class="header-top">
            <div class="header-container">
                <div class="logo-nav-container">
                    <img src="/images/logo.png" alt="AsFi" class="logo-img" onerror="this.style.display='none';">
                    <div class="nav-tabs">
                        <button class="nav-tab" onclick="window.location.href='/Student/Index'"><i class="bi bi-journal-bookmark"></i> Лекции</button>
                        <button class="nav-tab" onclick="window.location.href='/Student/Index?tab=tests'"><i class="bi bi-journal-text"></i> Тесты</button>
                        <button class="nav-tab active" onclick="window.location.href='/Student/TestResults'"><i class="bi bi-award"></i> Оценки</button>
                    </div>
                </div>
                <div class="search-container"><input type="text" class="search-input" placeholder="Поиск..." id="searchInput"><i class="bi bi-search search-icon"></i></div>
                <div class="header-right">
                    <div class="user-info" id="userInfo" style="cursor:pointer" onclick="window.location.href='/Student/Profile'">
                        <div><i class="bi bi-person-circle user-icon" id="defaultUserIcon"></i><img id="userAvatarImg" style="display:none; width:20px; height:20px; border-radius:50%;" /></div>
                        <span id="userName">Загрузка...</span>
                    </div>
                    <div id="groupStatusArea"></div>
                    <form asp-controller="Account" asp-action="Logout" method="post"><button type="submit" class="btn-logout"><i class="bi bi-box-arrow-right"></i> Выйти</button></form>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="teacher-card">
                <div class="teacher-card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="text-white"><i class="bi bi-award"></i> Мои результаты</h1>
                        <a href="/Student/ExportTestResultsToExcel" class="btn btn-success">
                            <i class="bi bi-file-earmark-excel"></i> Экспорт в Excel
                        </a>
                    </div>
                    @if (!Model.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-emoji-frown empty-state-icon"></i>
                            <h5>Пока нет результатов</h5>
                            <p>Вы ещё не прошли ни одного теста</p>
                            <a href="/Student/Index?tab=tests" class="btn btn-primary">Перейти к тестам</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover text-white">
                                <thead>
                                    <tr class="text-white-50">
                                        <th>Тест</th>
                                        <th>Тема</th>
                                        <th>Баллы</th>
                                        <th>Оценка</th>
                                        <th>Процент</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in Model)
                                    {
                                        var percent = r.PossiblePoints > 0 ? (r.ScoredPoints / r.PossiblePoints) * 100 : 0;
                                        var gradeClass = r.Grade >= 8 ? "grade-excellent" : (r.Grade >= 6 ? "grade-good" : (r.Grade >= 4 ? "grade-satisfactory" : "grade-poor"));
                                        <tr>
                                            <td><strong>@r.TestTitle</strong></td>
                                            <td>@r.TestTopic</td>
                                            <td>@r.ScoredPoints / @r.PossiblePoints</td>
                                            <td><span class="grade-badge @gradeClass" style="font-size:0.9rem;">@r.Grade / 10</span></td>
                                            <td>@percent.ToString("0.0")%</td>
                                            <td>
                                                <a href="/Student/TestResult/@r.Id" class="btn btn-sm btn-info">
                                                    <i class="bi bi-eye"></i> Детали
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    <div class="text-center mt-4">
                        <a href="/Student/Index" class="btn btn-secondary"><i class="bi bi-house"></i> На главную</a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function loadCurrentUser() {
            const res = await fetch('/Student/GetCurrentUser');
            const data = await res.json();
            if (data.success) {
                document.getElementById('userName').innerText = `${data.lastName} ${data.firstName}`;
                if (data.avatarUrl) {
                    document.getElementById('defaultUserIcon').style.display = 'none';
                    document.getElementById('userAvatarImg').src = data.avatarUrl;
                    document.getElementById('userAvatarImg').style.display = 'inline-block';
                }
            }
        }
        async function loadUserGroup() {
            const res = await fetch('/Student/GetUserGroup');
            const data = await res.json();
            if (data.success) {
                document.getElementById('groupStatusArea').innerHTML = `<div class="user-info" style="background:rgba(123,74,227,0.2);"><i class="bi bi-people-fill"></i><span>${escapeHtml(data.groupName)}</span></div>`;
            } else {
                document.getElementById('groupStatusArea').innerHTML = `<button class="btn-join-group" data-bs-toggle="modal" data-bs-target="#joinGroupModal"><i class="bi bi-people"></i> Вступить в группу</button>`;
            }
        }
        function escapeHtml(s) { return s?.replace(/[&<>]/g, m => m == '&' ? '&amp;' : m == '<' ? '&lt;' : '&gt;') || ''; }
        document.addEventListener('DOMContentLoaded', () => { loadCurrentUser(); loadUserGroup(); });

        
        document.getElementById('searchInput')?.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        });
    </script>
    <script src="~/js/theme.js"></script>
</body>
</html>