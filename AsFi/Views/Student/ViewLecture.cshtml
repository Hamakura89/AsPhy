@model AsFi.Models.Lecture
@{
    ViewData["Title"] = Model?.Title ?? "Лекция";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lecture-view.css" asp-append-version="true" />
</head>
<body>
    <div class="decoration decoration-1"></div>
    <div class="decoration decoration-2"></div>

    
    <header class="main-header">
        <div class="header-top">
            <div class="header-container">
                <div class="logo-nav-container">
                    <img src="/images/logo.png" alt="AsFi" class="logo-img" onerror="this.style.display='none';">
                    <div class="nav-tabs">
                        <button class="nav-tab" onclick="window.location.href='/Student/Index'">
                            <i class="bi bi-journal-bookmark"></i> Лекции
                        </button>
                        <button class="nav-tab" onclick="window.location.href='/Student/Index?tab=tests'">
                            <i class="bi bi-journal-text"></i> Тесты
                        </button>
                        <button class="nav-tab" onclick="window.location.href='/Student/TestResults'">
                            <i class="bi bi-award"></i> Оценки
                        </button>
                    </div>
                </div>

                <div class="search-container">
                    <input type="text" class="search-input" placeholder="Поиск по названию..." id="searchInput">
                    <i class="bi bi-search search-icon"></i>
                </div>

                <div class="header-right">
                    <div class="user-info" id="userInfo" style="cursor:pointer" onclick="window.location.href='/Student/Profile'">
                        <div id="userAvatarContainer" style="display:inline-flex; align-items:center; justify-content:center; width:20px; height:20px;">
                            <i class="bi bi-person-circle user-icon" id="defaultUserIcon"></i>
                            <img id="userAvatarImg" style="display:none; width:20px; height:20px; border-radius:50%; object-fit:cover;" />
                        </div>
                        <span id="userName">Загрузка...</span>
                    </div>

                    <div id="groupStatusArea"></div>

                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn-logout">
                            <i class="bi bi-box-arrow-right"></i> Выйти
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            @if (Model == null)
            {
                <div class="alert alert-danger">Лекция не найдена</div>
                <a href="/Student/Index" class="back-link"><i class="bi bi-arrow-left"></i> На главную</a>
            }
            else
            {
               
                <div class="teacher-card mb-4">
                    <div class="teacher-card-body">
                        <h1 class="text-white mb-3">@Model.Title</h1>
                        <div class="d-flex flex-wrap gap-3 mb-4">
                            @{
                                string typeName = Model.LectureType?.Name ?? "";
                                string typeBadgeClass = typeName.ToLower() == "лекция" ? "lecture" : (typeName.ToLower() == "видео" ? "video" : "presentation");
                                string typeIcon = typeName.ToLower() == "лекция" ? "bi-journal-text" : (typeName.ToLower() == "видео" ? "bi-play-circle" : "bi-file-earmark-slides");
                            }
                            <span class="lecture-type-badge @typeBadgeClass">
                                <i class="bi @typeIcon"></i> @(string.IsNullOrEmpty(typeName) ? "не указан" : typeName)
                            </span>
                            @if (Model.Topic != null)
                            {
                                <span class="test-duration-badge">
                                    <i class="bi bi-tag"></i> Тема: @Model.Topic.Name
                                </span>
                            }
                            @if (Model.Topic?.Subject != null)
                            {
                                <span class="test-duration-badge">
                                    <i class="bi bi-book"></i> Предмет: @Model.Topic.Subject.Name
                                </span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Comment))
                        {
                            <div class="alert alert-info mb-4">
                                <i class="bi bi-info-circle-fill me-2"></i> @Model.Comment
                            </div>
                        }
                    </div>
                </div>

                
                @if (Model.LectureType?.Name?.ToLower() == "видео")
                {
                    <div class="video-full-width">
                        @if (!string.IsNullOrEmpty(Model.Content))
                        {
                            string videoUrl = Model.Content;
                            if (videoUrl.Contains("youtube.com/watch?v="))
                            {
                                videoUrl = videoUrl.Replace("watch?v=", "embed/");
                            }
                            else if (videoUrl.Contains("youtu.be/"))
                            {
                                videoUrl = videoUrl.Replace("youtu.be/", "www.youtube.com/embed/");
                            }
                            if (videoUrl.Contains("embed/") && !videoUrl.Contains("?autoplay=0"))
                            {
                                videoUrl += (videoUrl.Contains("?") ? "&" : "?") + "autoplay=0";
                            }
                            <iframe src="@videoUrl" allowfullscreen></iframe>
                        }
                        else
                        {
                            <div class="alert alert-warning">Видео-ссылка отсутствует</div>
                        }
                    </div>
                    <div class="text-center mt-3">
                        <a href="@Model.Content" target="_blank" class="btn-view video" style="display: inline-block; width: auto; padding: 12px 30px;">
                            <i class="bi bi-box-arrow-up-right"></i> Открыть видео на весь экран
                        </a>
                    </div>
                }
                else if (Model.LectureType?.Name?.ToLower() == "презентация")
                {
                    string[] presentationUrls = string.IsNullOrEmpty(Model.Content)
                    ? Array.Empty<string>()
                    : Model.Content.Split(';', StringSplitOptions.RemoveEmptyEntries);

                    <div class="presentation-card">
                        <div class="presentation-icon">
                            <i class="bi bi-file-earmark-slides-fill"></i>
                        </div>
                        <h4 class="text-white mb-3">Презентация</h4>
                        @if (presentationUrls.Length == 0)
                        {
                            <p class="text-white-50">Файлы презентации не загружены.</p>
                        }
                        else
                        {
                            <p class="text-white-50 mb-4">Доступные файлы:</p>
                            <div class="text-start">
                                @foreach (var url in presentationUrls)
                                {
                                    string fileName = System.IO.Path.GetFileName(url);
                                    <div class="presentation-file-item">
                                        <a href="@url" target="_blank" class="presentation-file-name">
                                            <i class="bi bi-file-earmark-slides"></i> @fileName
                                        </a>
                                        <div class="d-flex gap-2">
                                            <a href="@url" target="_blank" class="btn-view presentation" style="width: auto; padding: 8px 16px;">
                                                <i class="bi bi-eye"></i> Открыть
                                            </a>
                                            <a href="@url" download class="btn-view presentation" style="width: auto; padding: 8px 16px;">
                                                <i class="bi bi-download"></i> Скачать
                                            </a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mt-4">
                                <img src="@Model.ImageUrl" alt="Превью" style="max-width: 200px; border-radius: 12px; margin-top: 20px;">
                            </div>
                        }
                    </div>
                }
                else
                {
                   
                    <div class="lecture-content-text">
                        @Html.Raw(Model.Content)
                    </div>
                }

               
                <div class="text-center">
                    <a href="/Student/Index" class="back-link">
                        <i class="bi bi-arrow-left"></i> На главную
                    </a>
                </div>
            }
        </div>
    </main>

    
    <div class="modal fade" id="joinGroupModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-people me-2"></i>Вступить в группу</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">Введите кодовое слово, которое предоставил преподаватель:</p>
                    <div class="mb-3">
                        <label for="inviteCodeModal" class="form-label">Кодовое слово:</label>
                        <input type="text" class="form-control" id="inviteCodeModal" placeholder="Введите кодовое слово" maxlength="20">
                        <div class="invalid-feedback" id="inviteCodeErrorModal"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary" id="joinGroupBtnModal"><i class="bi bi-check-lg"></i> Вступить</button>
                </div>
            </div>
        </div>
    </div>

    <div class="notification-container" id="notificationContainer"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        
        let currentGroupName = null;

        async function loadCurrentUser() {
            try {
                const response = await fetch('/Student/GetCurrentUser');
                const data = await response.json();
                if (data.success) {
                    const userName = `${data.lastName} ${data.firstName}`;
                    document.getElementById('userName').textContent = userName;
                    if (data.avatarUrl) {
                        document.getElementById('defaultUserIcon').style.display = 'none';
                        const img = document.getElementById('userAvatarImg');
                        img.src = data.avatarUrl;
                        img.style.display = 'inline-block';
                    } else {
                        document.getElementById('defaultUserIcon').style.display = 'inline-block';
                        document.getElementById('userAvatarImg').style.display = 'none';
                    }
                } else {
                    document.getElementById('userName').textContent = 'Студент';
                }
            } catch (error) {
                console.error(error);
                document.getElementById('userName').textContent = 'Студент';
            }
        }

        async function loadUserGroup() {
            try {
                const response = await fetch('/Student/GetUserGroup');
                const data = await response.json();
                if (data.success) {
                    currentGroupName = data.groupName;
                } else {
                    currentGroupName = null;
                }
                renderGroupStatus();
            } catch (error) {
                currentGroupName = null;
                renderGroupStatus();
            }
        }

        function renderGroupStatus() {
            const container = document.getElementById('groupStatusArea');
            if (currentGroupName) {
                container.innerHTML = `
                    <div class="user-info" style="background: rgba(123,74,227,0.2);">
                        <i class="bi bi-people-fill user-icon"></i>
                        <span>${escapeHtml(currentGroupName)}</span>
                    </div>
                `;
            } else {
                container.innerHTML = `
                    <button type="button" class="btn-join-group" data-bs-toggle="modal" data-bs-target="#joinGroupModal">
                        <i class="bi bi-people"></i> Вступить в группу
                    </button>
                `;
            }
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, m => {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        async function joinGroupFromModal() {
            const code = document.getElementById('inviteCodeModal').value.trim();
            const btn = document.getElementById('joinGroupBtnModal');
            const errorDiv = document.getElementById('inviteCodeErrorModal');
            if (!code) {
                errorDiv.textContent = 'Введите код';
                document.getElementById('inviteCodeModal').classList.add('is-invalid');
                return;
            }
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            try {
                const res = await fetch('/Student/JoinGroup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ inviteCode: code })
                });
                const result = await res.json();
                if (result.success) {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('joinGroupModal'));
                    modal.hide();
                    showNotification(result.message, 'success');
                    await loadUserGroup();
                    document.getElementById('inviteCodeModal').value = '';
                    document.getElementById('inviteCodeModal').classList.remove('is-invalid');
                } else {
                    errorDiv.textContent = result.message;
                    document.getElementById('inviteCodeModal').classList.add('is-invalid');
                }
            } catch (err) {
                errorDiv.textContent = 'Ошибка сети';
                document.getElementById('inviteCodeModal').classList.add('is-invalid');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg"></i> Вступить';
            }
        }

        function showNotification(msg, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 end-0 m-3`;
            alertDiv.style.zIndex = 9999;
            alertDiv.innerHTML = msg + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
            document.body.appendChild(alertDiv);
            setTimeout(() => alertDiv.remove(), 4000);
        }

        document.addEventListener('DOMContentLoaded', async function() {
            await loadCurrentUser();
            await loadUserGroup();

            const joinBtn = document.getElementById('joinGroupBtnModal');
            if (joinBtn) joinBtn.addEventListener('click', joinGroupFromModal);
            const inviteInput = document.getElementById('inviteCodeModal');
            if (inviteInput) {
                inviteInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') joinGroupFromModal();
                });
                inviteInput.addEventListener('input', function() {
                    this.classList.remove('is-invalid');
                    document.getElementById('inviteCodeErrorModal').textContent = '';
                });
            }

            document.getElementById('searchInput').addEventListener('input', function() {});
        });
    </script>
</body>
</html>