@model AsFi.Models.Lecture
@{
    ViewData["Title"] = $"Редактирование лекции: {Model.Title}";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard-styles.css" asp-append-version="true" />
    <style>
        .editor-toolbar {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--glass-border);
            border-bottom: none;
            padding: 10px;
            border-radius: 8px 8px 0 0;
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            align-items: center;
        }

        .toolbar-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid var(--glass-border);
            color: var(--glass-text);
            border-radius: 6px;
            padding: 6px 12px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .toolbar-btn:hover {
                background: rgba(255,255,255,0.2);
                border-color: var(--accent-2);
            }

        .toolbar-select {
            background: rgba(255,255,255,0.1);
            border: 1px solid var(--glass-border);
            color: var(--glass-text);
            border-radius: 6px;
            padding: 6px 12px;
            cursor: pointer;
        }

        .editor-content {
            background: white !important;
            color: #333 !important;
            border: 1px solid var(--glass-border);
            border-radius: 0 0 8px 8px;
            min-height: 400px;
            padding: 20px;
        }

            .editor-content img {
                max-width: 100%;
                cursor: pointer;
            }

        .file-list {
            margin-top: 15px;
            background: rgba(255,255,255,0.02);
            border-radius: 8px;
            padding: 10px;
        }

        .file-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 12px;
            border-bottom: 1px solid var(--glass-border);
        }

            .file-item:last-child {
                border-bottom: none;
            }

        .file-name {
            color: var(--glass-text);
            text-decoration: none;
        }

            .file-name:hover {
                text-decoration: underline;
            }

        .btn-sm {
            padding: 4px 8px;
            font-size: 12px;
        }
    </style>
</head>
<body class="teacher-body">
    <div class="decoration decoration-1"></div>
    <div class="decoration decoration-2"></div>

    <header class="teacher-header">
        <div class="header-top">
            <div class="header-container">
                <div class="logo-nav-container">
                    <img src="/images/logo.png" alt="AsFi" class="logo-img" onerror="this.style.display='none';">
                    <div class="teacher-nav-tabs">
                        <button class="teacher-nav-tab active" onclick="window.location.href='/Teacher/Index'">
                            <i class="bi bi-journal-bookmark"></i> Лекции
                        </button>
                        <button class="teacher-nav-tab">
                            <i class="bi bi-journal-text"></i> Тесты
                        </button>
                    </div>
                </div>
                <div class="header-right">
                    <div class="teacher-user-info" id="userInfo">
                        <i class="bi bi-person-circle user-icon"></i>
                        <span id="userName">Преподаватель</span>
                    </div>
                    <a href="/Teacher/Index" class="home-btn" style="text-decoration: none;">
                        <i class="bi bi-house"></i> На главную
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="edit-header">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="text-white">Редактирование лекции</h2>
                    <a href="/Teacher/Index" class="home-btn">
                        <i class="bi bi-arrow-left"></i> Назад к лекциям
                    </a>
                </div>
            </div>

            <div class="teacher-card mb-4">
                <div class="teacher-card-header">
                    <h4 class="mb-0 text-white"><i class="bi bi-info-circle"></i> Основная информация</h4>
                </div>
                <div class="teacher-card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Тема</label>
                            <select class="form-control" id="lectureTopicId">
                                @if (ViewBag.Topics != null)
                                {
                                    foreach (var topic in ViewBag.Topics as List<AsFi.Models.Topic>)
                                    {
                                        <option value="@topic.Id" selected="@(Model.TopicId == topic.Id)">@topic.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Название лекции</label>
                            <input type="text" class="form-control" id="lectureTitle" value="@Model.Title" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Тип лекции</label>
                            <select class="form-control" id="lectureTypeId">
                                <option value="1" selected="@(Model.LectureTypeId == 1)">Лекция (текст)</option>
                                <option value="2" selected="@(Model.LectureTypeId == 2)">Видео</option>
                                <option value="3" selected="@(Model.LectureTypeId == 3)">Презентация</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">URL изображения (обложка)</label>
                            <input type="text" class="form-control" id="lectureImageUrl" value="@Model.ImageUrl" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="teacher-card mb-4">
                <div class="teacher-card-header">
                    <h4 class="mb-0 text-white"><i class="bi bi-file-earmark-text"></i> Содержание лекции</h4>
                </div>
                <div class="teacher-card-body">
                   
                    <div id="textContentSection" class="content-section" style="@(Model.LectureTypeId == 1 ? "" : "display:none")">
                        <div class="editor-toolbar">
                            <select id="fontFamilySelect" class="toolbar-select" style="min-width: 120px;">
                                <option value="Arial">Arial</option>
                                <option value="Times New Roman">Times New Roman</option>
                                <option value="Courier New">Courier New</option>
                                <option value="Georgia">Georgia</option>
                                <option value="Verdana">Verdana</option>
                            </select>
                            <select id="fontSizeSelect" class="toolbar-select">
                                <option value="8">8 pt</option>
                                <option value="10">10 pt</option>
                                <option value="12">12 pt</option>
                                <option value="14">14 pt</option>
                                <option value="16">16 pt</option>
                                <option value="18">18 pt</option>
                                <option value="24">24 pt</option>
                                <option value="36">36 pt</option>
                                <option value="48">48 pt</option>
                                <option value="72">72 pt</option>
                            </select>
                            <button type="button" class="toolbar-btn" onclick="formatText('bold')"><i class="bi bi-type-bold"></i></button>
                            <button type="button" class="toolbar-btn" onclick="formatText('italic')"><i class="bi bi-type-italic"></i></button>
                            <button type="button" class="toolbar-btn" onclick="formatText('underline')"><i class="bi bi-type-underline"></i></button>
                            <button type="button" class="toolbar-btn" onclick="setAlign('left')"><i class="bi bi-text-left"></i></button>
                            <button type="button" class="toolbar-btn" onclick="setAlign('center')"><i class="bi bi-text-center"></i></button>
                            <button type="button" class="toolbar-btn" onclick="setAlign('right')"><i class="bi bi-text-right"></i></button>
                            <button type="button" class="toolbar-btn" onclick="setAlign('justify')"><i class="bi bi-justify"></i></button>
                            <button type="button" class="toolbar-btn" onclick="insertImage()"><i class="bi bi-image"></i> Изображение</button>
                            <button type="button" class="toolbar-btn" onclick="insertLink()"><i class="bi bi-link"></i> Ссылка</button>
                            <button type="button" class="toolbar-btn" onclick="insertTable()"><i class="bi bi-table"></i> Таблица</button>
                            <button type="button" class="toolbar-btn" onclick="resizeSelectedImage()"><i class="bi bi-arrows-angle-expand"></i> Размер изображения</button>
                            <input type="file" id="imageUpload" accept="image/*" style="display:none" onchange="handleImageUpload(this.files[0])" />
                        </div>
                        <div class="editor-content" contenteditable="true" id="lectureContent">@Html.Raw(Model.Content)</div>
                    </div>

                    
                    <div id="videoContentSection" class="content-section" style="@(Model.LectureTypeId == 2 ? "" : "display:none")">
                        <div class="mb-3">
                            <label class="form-label">Ссылка на видео (YouTube, Vimeo)</label>
                            <input type="url" class="form-control" id="videoLink" value="@Model.Content" />
                        </div>
                        <div id="videoPreview" class="preview-container">
                            @if (!string.IsNullOrEmpty(Model.Content))
                            {
                                <div class="alert alert-info">
                                    <i class="bi bi-play-circle"></i> Текущее видео: <a href="@Model.Content" target="_blank">@Model.Content</a>
                                </div>
                            }
                        </div>
                    </div>

                    
                    <div id="presentationContentSection" class="content-section" style="@(Model.LectureTypeId == 3 ? "" : "display:none")">
                        <div class="mb-3">
                            <label class="form-label">Добавить презентацию (PDF, PPT, PPTX)</label>
                            <div class="file-upload-area" onclick="document.getElementById('presentationUpload').click()"
                                 ondrop="handlePresentationDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)">
                                <i class="bi bi-file-ppt" style="font-size:3rem; color:var(--accent-2);"></i>
                                <p class="mt-2 mb-1 text-white">Перетащите файл или нажмите для выбора</p>
                                <small class="text-white">Поддерживаемые форматы: PDF, PPT, PPTX</small>
                                <input type="file" id="presentationUpload" accept=".pdf,.ppt,.pptx" style="display:none" onchange="handlePresentationUpload(this.files[0])" />
                            </div>
                        </div>
                        <div id="presentationList" class="file-list">
                            @if (!string.IsNullOrEmpty(Model.Content))
                            {
                                
                                var urls = Model.Content.Split(';', StringSplitOptions.RemoveEmptyEntries);
                                foreach (var url in urls)
                                {
                                    <div class="file-item" data-url="@url">
                                        <a href="@url" target="_blank" class="file-name">@System.IO.Path.GetFileName(url)</a>
                                        <div>
                                            <a href="@url" download class="btn btn-sm btn-outline-light me-2"><i class="bi bi-download"></i></a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removePresentationFile(this)"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <input type="hidden" id="presentationUrls" value="@Model.Content" />
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="fixed-bottom-bar">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div><small class="text-white">Лекция: <strong>@Model.Title</strong></small></div>
                <button id="saveLectureBtn" class="teacher-btn-purple btn-lg"><i class="bi bi-check-circle"></i> Сохранить лекцию</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let uploadedFiles = { presentation: [], images: [] };
        let presentationUrls = [];

        async function loadUserName() {
            try {
                const res = await fetch('/Teacher/GetCurrentUser');
                const data = await res.json();
                if (data.success) document.getElementById('userName').innerText = `${data.firstName} ${data.lastName}`;
            } catch { }
        }

        async function loadTopics() {
            const res = await fetch('/Teacher/GetTopics');
            const topics = await res.json();
            const select = document.getElementById('lectureTopicId');
            select.innerHTML = '';
            topics.forEach(t => {
                const option = document.createElement('option');
                option.value = t.id;
                option.textContent = t.name;
                if (t.id == @Model.TopicId) option.selected = true;
                select.appendChild(option);
            });
        }

        function formatText(cmd) { document.execCommand(cmd, false, null); document.getElementById('lectureContent').focus(); }
        function setAlign(align) { document.execCommand('justify' + align.charAt(0).toUpperCase() + align.slice(1), false, null); document.getElementById('lectureContent').focus(); }
        function insertImage() { document.getElementById('imageUpload').click(); }
        function insertLink() { const url = prompt('Введите URL:'); if (url) document.execCommand('createLink', false, url); }

        
                function insertTable() {
            const modalHtml = `
                <div class="modal fade" id="tableModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title text-white">Вставить таблицу</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Строки</label>
                                    <input type="number" id="tableRows" class="form-control" min="1" max="20" value="3">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Столбцы</label>
                                    <input type="number" id="tableCols" class="form-control" min="1" max="20" value="3">
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                <button type="button" class="btn btn-primary" id="confirmTableBtn">Вставить</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            const existing = document.getElementById('tableModal');
            if (existing) existing.remove();
            document.body.insertAdjacentHTML('beforeend', modalHtml);
            const modal = new bootstrap.Modal(document.getElementById('tableModal'));
            modal.show();

            document.getElementById('confirmTableBtn').onclick = () => {
                const rows = parseInt(document.getElementById('tableRows').value) || 3;
                const cols = parseInt(document.getElementById('tableCols').value) || 3;

                
                let table = '<table style="border-collapse: collapse; width: 100%; background: white; margin: 10px 0;">';
                for (let i = 0; i < rows; i++) {
                    table += '<tr>';
                    for (let j = 0; j < cols; j++) {
                        table += '<td style="border: 1px solid black; padding: 8px;">&nbsp;</td>';
                    }
                    table += '</tr>';
                }
                table += '</table><br>';

               
                const editor = document.getElementById('lectureContent');
                editor.focus();
                if (document.queryCommandSupported('insertHTML')) {
                    document.execCommand('insertHTML', false, table);
                } else {
                   
                    const sel = window.getSelection();
                    if (sel.rangeCount) {
                        const range = sel.getRangeAt(0);
                        range.deleteContents();
                        const frag = range.createContextualFragment(table);
                        range.insertNode(frag);
                        range.collapse(false);
                    } else {
                        editor.innerHTML += table;
                    }
                }
                modal.hide();
                document.getElementById('tableModal').remove();
            };
        }

        
        function resizeSelectedImage() {
            const editor = document.getElementById('lectureContent');
            editor.focus();

            let img = null;
            const selection = window.getSelection();
            if (selection.rangeCount > 0) {
                let node = selection.anchorNode;
                if (node.nodeType === 3) node = node.parentElement;
                if (node && node.tagName === 'IMG') img = node;
                else {
                    const range = selection.getRangeAt(0);
                    const container = range.commonAncestorContainer;
                    if (container.nodeType === 3) img = container.parentElement.querySelector('img');
                    else img = container.querySelector('img');
                }
            }

            if (!img) {
                alert('Пожалуйста, выделите изображение в редакторе');
                return;
            }

            
            const currentWidth = img.style.width ? parseInt(img.style.width) : img.width;
            const currentHeight = img.style.height ? parseInt(img.style.height) : img.height;

            const modalHtml = `
                <div class="modal fade" id="resizeImageModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title text-white">Изменить размер изображения</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Ширина (px)</label>
                                    <input type="number" id="imgWidth" class="form-control" value="${currentWidth || ''}" placeholder="Авто">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Высота (px)</label>
                                    <input type="number" id="imgHeight" class="form-control" value="${currentHeight || ''}" placeholder="Авто">
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="keepRatio" checked>
                                    <label class="form-check-label">Сохранять пропорции</label>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                <button type="button" class="btn btn-primary" id="applyResizeBtn">Применить</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            const existingModal = document.getElementById('resizeImageModal');
            if (existingModal) existingModal.remove();
            document.body.insertAdjacentHTML('beforeend', modalHtml);
            const modal = new bootstrap.Modal(document.getElementById('resizeImageModal'));
            modal.show();

            const widthInput = document.getElementById('imgWidth');
            const heightInput = document.getElementById('imgHeight');
            const keepRatio = document.getElementById('keepRatio');

            let naturalWidth = img.naturalWidth, naturalHeight = img.naturalHeight;
            if (!naturalWidth) {
                const temp = new Image();
                temp.src = img.src;
                temp.onload = () => {
                    naturalWidth = temp.width;
                    naturalHeight = temp.height;
                };
            }

            widthInput.addEventListener('input', () => {
                if (keepRatio.checked && naturalWidth && naturalHeight) {
                    const newW = parseInt(widthInput.value);
                    if (!isNaN(newW)) heightInput.value = Math.round(newW * naturalHeight / naturalWidth);
                }
            });
            heightInput.addEventListener('input', () => {
                if (keepRatio.checked && naturalWidth && naturalHeight) {
                    const newH = parseInt(heightInput.value);
                    if (!isNaN(newH)) widthInput.value = Math.round(newH * naturalWidth / naturalHeight);
                }
            });

            document.getElementById('applyResizeBtn').onclick = () => {
                const newWidth = widthInput.value;
                const newHeight = heightInput.value;
                if (newWidth) img.style.width = newWidth + 'px';
                else img.style.width = '';
                if (newHeight) img.style.height = newHeight + 'px';
                else img.style.height = '';
                modal.hide();
                document.getElementById('resizeImageModal').remove();
            };
        }

        async function handleImageUpload(file) {
            if (!file) return;
            if (!file.type.startsWith('image/')) { alert('Файл не изображение'); return; }
            const fd = new FormData(); fd.append('file', file);
            const res = await fetch('/Teacher/UploadFile', { method: 'POST', body: fd });
            const data = await res.json();
            if (data.success) {
                const img = document.createElement('img');
                img.src = data.path;
                img.style.maxWidth = '100%';
                img.style.cursor = 'pointer';
                const editor = document.getElementById('lectureContent');
                editor.focus();
                document.execCommand('insertHTML', false, img.outerHTML);
                uploadedFiles.images.push(data.path);
            } else alert('Ошибка загрузки: ' + data.message);
        }

        function handleDragOver(e) { e.preventDefault(); e.currentTarget.classList.add('dragover'); }
        function handleDragLeave(e) { e.preventDefault(); e.currentTarget.classList.remove('dragover'); }
        function handlePresentationDrop(e) { e.preventDefault(); e.currentTarget.classList.remove('dragover'); const files = e.dataTransfer.files; if (files.length) handlePresentationUpload(files[0]); }

        async function uploadFile(file) {
            const fd = new FormData(); fd.append('file', file);
            const res = await fetch('/Teacher/UploadFile', { method: 'POST', body: fd });
            return await res.json();
        }

        async function handlePresentationUpload(file) {
            if (!file) return;
            const ext = '.' + file.name.split('.').pop().toLowerCase();
            if (!['.pdf','.ppt','.pptx'].includes(ext)) { alert('Недопустимый формат'); return; }
            const result = await uploadFile(file);
            if (result.success) {
                presentationUrls.push(result.path);
                renderPresentationList();
                document.getElementById('presentationUpload').value = '';
            } else alert('Ошибка загрузки: ' + result.message);
        }

        function renderPresentationList() {
            const container = document.getElementById('presentationList');
            if (!container) return;
            if (presentationUrls.length === 0) {
                container.innerHTML = '<div class="text-white-50 text-center p-3">Нет загруженных презентаций</div>';
                return;
            }
            let html = '';
            presentationUrls.forEach(url => {
                const fileName = url.split('/').pop();
                html += `
                    <div class="file-item" data-url="${url}">
                        <a href="${url}" target="_blank" class="file-name">${fileName}</a>
                        <div>
                            <a href="${url}" download class="btn btn-sm btn-outline-light me-2"><i class="bi bi-download"></i></a>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removePresentationFileByUrl('${url}')"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        function removePresentationFileByUrl(url) {
            presentationUrls = presentationUrls.filter(u => u !== url);
            renderPresentationList();
        }

        async function saveLecture() {
            const saveBtn = document.getElementById('saveLectureBtn');
            const original = saveBtn.innerHTML;
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Сохранение...';

            const title = document.getElementById('lectureTitle')?.value?.trim() || '';
            const topicId = parseInt(document.getElementById('lectureTopicId')?.value) || 1;
            const lectureTypeId = parseInt(document.getElementById('lectureTypeId')?.value) || 1;
            const imageUrl = document.getElementById('lectureImageUrl')?.value?.trim() || '';

            let content = '';
            if (lectureTypeId === 1) {
                content = document.getElementById('lectureContent')?.innerHTML || '';
            }
            else if (lectureTypeId === 2) {
                content = document.getElementById('videoLink')?.value?.trim() || '';
            }
            else if (lectureTypeId === 3) {
                content = presentationUrls.join(';');
            }

            const data = {
                Id: @Model.Id,
                Title: title,
                TopicId: topicId,
                LectureTypeId: lectureTypeId,
                Content: content,
                Comment: '',
                ImageUrl: imageUrl
            };

            const res = await fetch('/Teacher/SaveLecture', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (result.success) {
                alert('Лекция сохранена');
                window.location.href = '/Teacher/Index';
            } else alert('Ошибка: ' + result.message);
            saveBtn.disabled = false;
            saveBtn.innerHTML = original;
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadUserName();
            loadTopics();
            document.getElementById('lectureTypeId').addEventListener('change', function() {
                const val = parseInt(this.value);
                document.getElementById('textContentSection').style.display = val === 1 ? '' : 'none';
                document.getElementById('videoContentSection').style.display = val === 2 ? '' : 'none';
                document.getElementById('presentationContentSection').style.display = val === 3 ? '' : 'none';
            });
            document.getElementById('saveLectureBtn').addEventListener('click', saveLecture);

            const urlsField = document.getElementById('presentationUrls');
            if (urlsField && urlsField.value) {
                presentationUrls = urlsField.value.split(';').filter(u => u.trim());
                renderPresentationList();
            }

            const editor = document.getElementById('lectureContent');
            if (editor) {
                const fontSelect = document.getElementById('fontFamilySelect');
                const sizeSelect = document.getElementById('fontSizeSelect');
                fontSelect.addEventListener('change', () => {
                    document.execCommand('fontName', false, fontSelect.value);
                    editor.focus();
                });
                sizeSelect.addEventListener('change', () => {
                    const pt = sizeSelect.value;
                    editor.focus();
                    document.execCommand('fontSize', false, '7');
                    const selection = window.getSelection();
                    if (!selection.isCollapsed && selection.rangeCount > 0) {
                        const range = selection.getRangeAt(0);
                        const span = document.createElement('span');
                        span.style.fontSize = pt + 'pt';
                        range.surroundContents(span);
                    }
                });
            }
        });
    </script>

    <script src="~/js/theme.js"></script>

</body>
</html>